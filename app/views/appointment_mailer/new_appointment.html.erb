<div style="font-family: Arial, sans-serif; padding: 20px; background-color: #f9f9f9;">
<h1>New Appointment</h1>
<p><strong>Name:</strong> <%= @appointment.name %></p>
<p><strong>Email:</strong> <%= @appointment.email %></p>
<p><strong>Date:</strong> <%= @appointment.appointment_date.strftime("%B %d, %Y") %></p>
<p><strong>Time:</strong> <%= @appointment.appointment_time.strftime("%I:%M %p") %></p>
<p><strong>Doctor:</strong> <%= @appointment.doctor.name %></p>
</div>
<a href="<%= rails_admin.show_path(model_name: 'appointment', id: @appointment.id, host: Rails.application.routes.default_url_options[:host]) %>"
   style="display: inline-block; margin-top: 20px; background-color: #2E7D32; color: #fff;
          padding: 10px 20px; text-decoration: none; border-radius: 8px;">
  View in Admin
</a>
